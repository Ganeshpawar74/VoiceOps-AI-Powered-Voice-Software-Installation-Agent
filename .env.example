# ============================================================
# VoiceOps — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1

# ── Database (PostgreSQL) ──────────────────────────────────
# If Postgres is not running, app uses in-memory fallback automatically
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ── Redis ──────────────────────────────────────────────────
# If Redis is not running, app falls back to in-process execution
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_BROKER=redis://localhost:6379/1
REDIS_CELERY_BACKEND=redis://localhost:6379/2

# ── LLM (Mistral) ──────────────────────────────────────────
# Get your key at https://console.mistral.ai/
LLM_PROVIDER=mistral
LLM_MISTRAL_API_KEY=your_mistral_api_key_here
LLM_INTENT_MODEL=mistral-small-latest
LLM_PLANNER_MODEL=mistral-small-latest
LLM_TOOL_MODEL=mistral-small-latest

# ── STT (Speech-to-Text) ───────────────────────────────────
# provider: "whisper" (local, free) OR "sarvam" (API, Hinglish-optimised)
STT_PROVIDER=whisper
STT_WHISPER_MODEL_SIZE=base
STT_WHISPER_DEVICE=cpu
STT_WHISPER_COMPUTE_TYPE=int8
# Only needed if STT_PROVIDER=sarvam:
STT_SARVAM_API_KEY=

# ── TTS (Text-to-Speech via Sarvam AI) ────────────────────
# Get your key at https://dashboard.sarvam.ai/
TTS_SARVAM_API_KEY=your_sarvam_api_key_here
TTS_TARGET_LANGUAGE_CODE=en-IN
TTS_SPEAKER=meera
TTS_MODEL=bulbul:v1

# ── Vector DB (RAG) — optional ─────────────────────────────
VECTOR_PROVIDER=qdrant
VECTOR_QDRANT_URL=http://localhost:6333
VECTOR_QDRANT_COLLECTION=voiceops_docs

# ── Security ───────────────────────────────────────────────
SEC_JWT_SECRET=change_this_to_a_long_random_string_in_production
SEC_REQUIRE_HTTPS=false
SEC_VERIFY_CHECKSUMS=false
SEC_VERIFY_PUBLISHER=false
SEC_MAX_FILE_SIZE_MB=4096

# ── Browser ────────────────────────────────────────────────
BROWSER_HEADLESS=true

# ── Feature Flags ──────────────────────────────────────────
FEATURE_RAG_ENABLED=false        # true requires Qdrant running
FEATURE_OCR_FALLBACK=true
FEATURE_VISION_FALLBACK=false
FEATURE_HUMAN_IN_LOOP=false
FEATURE_TTS_ENABLED=true         # false to disable Sarvam TTS

# ── Observability ──────────────────────────────────────────
OBS_LOG_LEVEL=DEBUG
OBS_LOG_FORMAT=text
OBS_ENABLE_TRACING=false
OBS_ENABLE_METRICS=true
OBS_JAEGER_ENDPOINT=http://localhost:14268/api/traces
