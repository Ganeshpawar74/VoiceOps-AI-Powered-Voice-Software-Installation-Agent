"""
Agent 7 — Monitoring Agent
Agent 8 — Notification Agent

FIXES:
  - BUG #3: `await aioredis.from_url(...)` — same await-on-sync-factory bug as
    task_store.py. Fixed: removed the await.
  - BUG #4: hasattr(task, 'intent_output') always True on Pydantic model →
    value-level check `if task.intent_output`.
  - All Redis operations wrapped in try/except (non-fatal if Redis is down).
"""

from __future__ import annotations

import asyncio
import logging
from datetime import datetime
from typing import Callable, Optional

import redis.asyncio as aioredis

from app.config.settings import get_settings
from app.models.schemas import InstallResult, NotificationEvent, Task, TaskStatus

logger   = logging.getLogger(__name__)
settings = get_settings()


# ══════════════════════════════════════════════
# Agent 7 — Monitoring Agent
# ══════════════════════════════════════════════

class MonitoringAgent:
    """
    Polls installation process state, publishes progress events to Redis pub/sub.

    BUG #3 FIX: _get_redis() used `await aioredis.from_url(...)`.
    In redis>=5.x from_url() is a sync factory — awaiting it raises TypeError
    which crashed every publish_progress() call (and therefore the notify node).
    Fix: call from_url() without await.
    """

    PROGRESS_CHANNEL = "voiceops:progress:{task_id}"

    def __init__(self):
        self._redis: Optional[aioredis.Redis] = None

    def _get_redis(self) -> aioredis.Redis:
        # BUG #3 FIX: was `await aioredis.from_url(...)` — from_url is NOT a coroutine
        if self._redis is None:
            self._redis = aioredis.from_url(
                str(settings.redis.url), decode_responses=True
            )
        return self._redis

    async def publish_progress(self, task_id: str, pct: int, message: str) -> None:
        try:
            r = self._get_redis()
            event = NotificationEvent(
                task_id=task_id,
                event="progress",
                message=message,
                data={"progress_pct": pct},
            )
            channel = self.PROGRESS_CHANNEL.format(task_id=task_id)
            await r.publish(channel, event.model_dump_json())
            logger.debug("[Monitoring] task=%s pct=%d msg=%s", task_id, pct, message)
        except Exception as exc:
            logger.debug("[Monitoring] publish_progress skipped (non-fatal): %s", exc)

    async def monitor(
        self,
        task: Task,
        install_task: asyncio.Task,
        on_progress: Optional[Callable[[int, str], None]] = None,
    ) -> InstallResult:
        """
        Watches install_task and emits synthetic progress events at milestones.
        Returns the InstallResult once complete.
        """
        milestones = [
            (10, "Starting installation..."),
            (30, "Installer running..."),
            (60, "Configuring..."),
            (85, "Finalizing..."),
        ]
        idx = 0

        while not install_task.done():
            if idx < len(milestones):
                pct, msg = milestones[idx]
                await self.publish_progress(task.task_id, pct, msg)
                if on_progress:
                    on_progress(pct, msg)
                idx += 1
            await asyncio.sleep(5)

        result = install_task.result()
        final_pct = 100 if result.success else 0
        final_msg = "Installation complete!" if result.success else f"Failed: {result.error}"
        await self.publish_progress(task.task_id, final_pct, final_msg)
        return result

    async def capture_logs(self, task_id: str, logs: list[str]) -> None:
        """Store install logs in Redis for debugging."""
        try:
            r   = self._get_redis()
            key = f"voiceops:logs:{task_id}"
            await r.rpush(key, *logs)
            await r.expire(key, settings.redis.ttl_session)
            logger.debug("[Monitoring] Captured %d log lines for task=%s", len(logs), task_id)
        except Exception as exc:
            logger.debug("[Monitoring] capture_logs skipped (non-fatal): %s", exc)


# ══════════════════════════════════════════════
# Agent 8 — Notification Agent
# ══════════════════════════════════════════════

class NotificationAgent:
    """
    Publishes final task completion events to Redis pub/sub and user channel.

    BUG #3 FIX: Same await-on-sync-factory fix as MonitoringAgent.
    BUG #4 FIX: hasattr check replaced with value-level check.
    """

    def __init__(self):
        self._redis: Optional[aioredis.Redis] = None

    def _get_redis(self) -> aioredis.Redis:
        # BUG #3 FIX: was `await aioredis.from_url(...)` — from_url is NOT a coroutine
        if self._redis is None:
            self._redis = aioredis.from_url(
                str(settings.redis.url), decode_responses=True
            )
        return self._redis

    def _format_message(self, task: Task) -> str:
        # BUG #4 FIX: was `if hasattr(task, 'intent_output')` — always True on Pydantic
        if task.intent_output:
            sw = task.intent_output.software_canonical or "the software"
        else:
            sw = "the software"

        if task.status == TaskStatus.COMPLETED:
            return f"{sw} has been installed successfully."
        elif task.status == TaskStatus.FAILED:
            return f"Failed to install {sw}: {task.error or 'unknown error'}"
        else:
            return f"Task {task.task_id} ended with status: {task.status.value}"

    async def notify(self, task: Task) -> None:
        """Publish final notification event to Redis user channel."""
        message = self._format_message(task)
        logger.info("[Notification] task=%s status=%s msg=%s",
                    task.task_id, task.status.value, message)

        event = NotificationEvent(
            task_id=task.task_id,
            event="completed" if task.status == TaskStatus.COMPLETED else "failed",
            message=message,
            data={
                "status":   task.status.value,
                "error":    task.error,
                "progress": 100 if task.status == TaskStatus.COMPLETED else 0,
            },
        )

        try:
            r = self._get_redis()
            # Publish to progress channel (SSE listeners)
            progress_ch = f"voiceops:progress:{task.task_id}"
            await r.publish(progress_ch, event.model_dump_json())
            # Publish to user notification channel (WebSocket listeners)
            notify_ch = f"voiceops:notify:{task.user_id}"
            await r.publish(notify_ch, event.model_dump_json())
            logger.debug("[Notification] Published to channels for task=%s", task.task_id)
        except Exception as exc:
            logger.warning("[Notification] Redis publish skipped (non-fatal): %s", exc)