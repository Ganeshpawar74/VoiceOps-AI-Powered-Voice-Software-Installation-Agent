"""
Master LangGraph Workflow — orchestrates all 8 agents.

Fixes vs original:
  1. _route_after_intent: download-only now correctly skips install node.
  2. BrowserAgent: no longer a module-level singleton — instantiated per task
     so Playwright browser state doesn't leak between tasks.
  3. node_download: __package_manager__ sentinel replaced with a typed flag
     (use_package_manager) in WorkflowState so InstallAgent never receives it.
  4. node_install: reads use_package_manager flag cleanly, no Path() on a sentinel.
  5. node_planner: RAG is now actually called (when FEATURE_RAG_ENABLED=true)
     to enrich install step params with real documentation context.
  6. human_in_loop checkpoint: when FEATURE_HUMAN_IN_LOOP=true, the workflow
     pauses after planning and publishes an approval-required event.
     The workflow only proceeds once the user sends an approval signal via Redis.
  7. MonitoringAgent.monitor(): fixes hasattr() bug — now checks
     `if task.intent_output` (value-level) instead of `hasattr`.
  8. run_voice_workflow: accepts os_hint from text tasks.
"""

from __future__ import annotations

import asyncio
import logging
from typing import Any, Optional, TypedDict

from langgraph.graph import END, StateGraph

from app.agents.download_agent.agent import DownloadAgent
from app.agents.install_agent.agent import InstallAgent
from app.agents.intent_agent.agent import IntentAgent
from app.agents.monitoring_agent.agent import MonitoringAgent, NotificationAgent
from app.agents.planner_agent.agent import PlannerAgent
from app.agents.speech_agent.agent import SpeechAgent
from app.config.settings import get_settings
from app.models.schemas import (
    AudioInput,
    BrowserResult,
    DownloadResult,
    ExecutionPlan,
    InstallResult,
    Intent,
    IntentOutput,
    Language,
    OperatingSystem,
    SpeechOutput,
    Task,
    TaskStatus,
)

logger   = logging.getLogger(__name__)
settings = get_settings()

# FIX: below this, a transcript is more likely to be a Whisper hallucination
# (built from a tiny VAD-retained fragment, or just genuinely unclear audio)
# than a real instruction. Below this we ask the user to retry instead of
# feeding the text into Intent/Planner, which can't tell "wrong" from "valid
# but unusual" and would otherwise just fail confusingly several steps later.
_MIN_SPEECH_CONFIDENCE = 0.55


# ──────────────────────────────────────────────
# Shared workflow state
# ──────────────────────────────────────────────

class WorkflowState(TypedDict):
    task: dict[str, Any]
    audio_bytes: Optional[bytes]
    text_query: Optional[str]
    os_hint: Optional[str]              # forwarded from text task
    speech: Optional[dict[str, Any]]
    intent: Optional[dict[str, Any]]
    plan: Optional[dict[str, Any]]
    rag_context: Optional[str]          # install guide snippet from RAG
    browser: Optional[dict[str, Any]]
    use_package_manager: bool           # True when planner chose a pkg manager
    download: Optional[dict[str, Any]]
    install: Optional[dict[str, Any]]
    error: Optional[str]
    current_step: str
    retry_count: int
    awaiting_approval: bool             # True when human_in_loop is waiting


# ──────────────────────────────────────────────
# Agent singletons — stateless agents only
# BrowserAgent is NOT a singleton — see node_browser() for explanation
# ──────────────────────────────────────────────

_speech_agent   = SpeechAgent()
_intent_agent   = IntentAgent()
_planner_agent  = PlannerAgent()
_download_agent = DownloadAgent()
_install_agent  = InstallAgent()
_monitor_agent  = MonitoringAgent()
_notify_agent   = NotificationAgent()


# ──────────────────────────────────────────────
# Node implementations
# ──────────────────────────────────────────────

async def node_speech(state: WorkflowState) -> WorkflowState:
    state["current_step"] = "speech"
    try:
        if state.get("audio_bytes"):
            audio = AudioInput(
                audio_bytes=state["audio_bytes"],
                session_id=state["task"]["session_id"],
            )
            result: SpeechOutput = await _speech_agent.process(audio)
        else:
            # Text path — wrap the query in a SpeechOutput so downstream
            # agents see the same interface regardless of input mode.
            result = SpeechOutput(
                query=state["text_query"] or "",
                language=Language.EN,
                confidence=1.0,
                raw_transcript=state["text_query"] or "",
                session_id=state["task"]["session_id"],
                processing_time_ms=0,
            )
        state["speech"] = result.model_dump()
        logger.info("[Workflow] Speech done: query=%r", result.query)

        # FIX: an empty/whitespace transcript (e.g. VAD classified the whole
        # clip as silence) used to fall through to Intent/Planner/Browser,
        # burning ~80s before failing with a confusing "no download link"
        # error. Fail fast here with an actionable message instead.
        if state.get("audio_bytes") and not result.query.strip():
            state["error"] = (
                "No speech detected in the recording. Please try again and "
                "speak clearly into the microphone."
            )
            logger.warning("[Workflow] Empty transcript — short-circuiting")

        # FIX: a non-empty but low-confidence transcript (e.g. VAD kept only
        # a sliver of the clip, so Whisper filled in a fluent-sounding but
        # wrong sentence — "I'll see you later" instead of "install VS Code")
        # used to sail straight into Intent/Planner/Browser and fail 30-80s
        # later with a confusing, unrelated error. Catch it here instead.
        elif state.get("audio_bytes") and result.confidence < _MIN_SPEECH_CONFIDENCE:
            state["error"] = (
                f"Wasn't able to clearly understand the recording (heard: "
                f"\"{result.query}\", but not confident). Please try again, "
                f"speaking a bit louder and closer to the microphone."
            )
            logger.warning(
                "[Workflow] Low-confidence transcript (%.2f < %.2f): %r — short-circuiting",
                result.confidence, _MIN_SPEECH_CONFIDENCE, result.query,
            )
    except Exception as exc:
        state["error"] = f"Speech agent error: {exc}"
        logger.error("[Workflow] Speech failed: %s", exc)
    return state


async def node_intent(state: WorkflowState) -> WorkflowState:
    state["current_step"] = "intent"
    if state.get("error"):
        return state
    try:
        speech = SpeechOutput(**state["speech"])
        result: IntentOutput = await _intent_agent.extract(speech)

        # If the caller supplied an os_hint (from the text API), override
        # the detected OS so intent always wins for explicit hints.
        if state.get("os_hint"):
            try:
                result = result.model_copy(
                    update={"operating_system": OperatingSystem(state["os_hint"])}
                )
            except ValueError:
                pass  # unknown hint value — keep detected OS

        state["intent"] = result.model_dump()
        logger.info("[Workflow] Intent done: %s / %s / os=%s",
                    result.intent, result.software_canonical, result.operating_system)
    except Exception as exc:
        state["error"] = f"Intent agent error: {exc}"
        logger.error("[Workflow] Intent failed: %s", exc)
    return state


async def node_planner(state: WorkflowState) -> WorkflowState:
    """
    Builds the execution plan.
    Also queries RAG (when FEATURE_RAG_ENABLED=true) to pull any relevant
    install guide snippet into state["rag_context"] for use by node_install.
    """
    state["current_step"] = "planner"
    if state.get("error"):
        return state
    try:
        intent = IntentOutput(**state["intent"])
        plan: ExecutionPlan = await _planner_agent.plan(intent)
        state["plan"] = plan.model_dump()

        # ── RAG enrichment ──
        # Query the vector store for an installation guide snippet.
        # This context is passed to InstallAgent so it can use documented
        # flags/switches (e.g. /VERYSILENT for NSIS installers).
        state["rag_context"] = None
        if settings.features.rag_enabled:
            try:
                from app.rag.store import RAGStore
                rag = RAGStore()
                guide = await rag.get_install_guide(
                    software=intent.software_canonical,
                    os_target=intent.operating_system.value,
                )
                if guide:
                    state["rag_context"] = guide
                    logger.info("[Workflow] RAG context retrieved for %s/%s",
                                intent.software_canonical, intent.operating_system.value)
            except Exception as exc:
                # RAG failure is non-fatal — log and continue without context
                logger.warning("[Workflow] RAG lookup failed (non-fatal): %s", exc)

        logger.info("[Workflow] Planner done: %d steps, rag=%s",
                    len(plan.steps), bool(state["rag_context"]))

        # FIX: zero steps means the planner couldn't map the request to any
        # known action (e.g. intent stayed UNKNOWN, or software wasn't
        # recognised). Previously this fell through to node_browser, which
        # spent 30-45s launching Chromium + OCR fallback to search for an
        # empty software name, then failed with a confusing browser-level
        # error. Fail fast here with a message the user can act on.
        if not plan.steps:
            state["error"] = (
                "Couldn't understand what software to install from that "
                "request. Please try again, e.g. \"install Google Chrome\"."
            )
    except Exception as exc:
        state["error"] = f"Planner agent error: {exc}"
        logger.error("[Workflow] Planner failed: %s", exc)
    return state


async def node_human_approval(state: WorkflowState) -> WorkflowState:
    """
    Human-in-the-loop checkpoint (only active when FEATURE_HUMAN_IN_LOOP=true).

    Publishes an 'approval_required' event to the task's Redis progress channel,
    then waits up to 5 minutes for an approval signal published to
    'voiceops:approval:{task_id}'.

    The client (browser/CLI) must publish b'approved' or b'rejected' to that channel.
    If no signal arrives within the timeout, the task is rejected automatically.
    """
    state["current_step"] = "human_approval"
    if state.get("error"):
        return state

    if not settings.features.human_in_loop:
        state["awaiting_approval"] = False
        return state

    task_id = state["task"]["task_id"]
    plan    = ExecutionPlan(**state["plan"])
    intent  = IntentOutput(**state["intent"])

    import json
    import redis.asyncio as aioredis
    from app.models.schemas import NotificationEvent

    r = await aioredis.from_url(str(settings.redis.url), decode_responses=True)

    # Publish approval-required event so the UI can show a confirmation dialog
    approval_event = NotificationEvent(
        task_id=task_id,
        event="approval_required",
        message=(
            f"About to install {intent.software_canonical} "
            f"on {intent.operating_system.value}. Approve?"
        ),
        data={
            "software": intent.software_canonical,
            "os":       intent.operating_system.value,
            "steps":    len(plan.steps),
        },
    )
    progress_channel = f"voiceops:progress:{task_id}"
    await r.publish(progress_channel, approval_event.model_dump_json())

    # Wait for approval signal
    approval_channel = f"voiceops:approval:{task_id}"
    async with r.pubsub() as pubsub:
        await pubsub.subscribe(approval_channel)
        try:
            decision = await asyncio.wait_for(
                _wait_for_approval_signal(pubsub),
                timeout=300,  # 5 minutes
            )
        except asyncio.TimeoutError:
            decision = "rejected"
        finally:
            await pubsub.unsubscribe(approval_channel)

    await r.aclose()

    if decision != "approved":
        state["error"] = "Installation cancelled: user did not approve"
        logger.info("[Workflow] Human approval rejected for task=%s", task_id)
    else:
        state["awaiting_approval"] = False
        logger.info("[Workflow] Human approval granted for task=%s", task_id)

    return state


async def _wait_for_approval_signal(pubsub) -> str:
    """Drain pubsub messages until we get 'approved' or 'rejected'."""
    while True:
        message = await pubsub.get_message(ignore_subscribe_messages=True)
        if message and message["type"] == "message":
            signal = str(message["data"]).strip().lower()
            if signal in ("approved", "rejected"):
                return signal
        await asyncio.sleep(0.5)


async def node_browser(state: WorkflowState) -> WorkflowState:
    """
    Finds the installer download link via Playwright.

    FIX: BrowserAgent is instantiated fresh per task (not a module singleton).
    The original singleton caused Playwright's browser to silently fail after
    the first navigation error — all subsequent tasks would fail until worker restart.
    Instantiating per task is cheap: the browser process itself is reused by
    Playwright's internal process manager; only the Python wrapper is new.
    """
    state["current_step"] = "browser"
    if state.get("error"):
        return state

    # Package-manager path: skip browser entirely, set flag for node_download
    plan = ExecutionPlan(**state["plan"])
    if len(plan.steps) == 1 and "pkg_manager" in plan.steps[0].name:
        state["use_package_manager"] = True
        state["browser"] = BrowserResult(
            success=True,
            navigation_path=["package_manager"],
        ).model_dump()
        return state

    state["use_package_manager"] = False

    # Fresh BrowserAgent per task — no state leak between tasks
    from app.agents.browser_agent.agent import BrowserAgent
    browser_agent = BrowserAgent()
    try:
        intent = IntentOutput(**state["intent"])
        result: BrowserResult = await browser_agent.find_download_link(intent)
        state["browser"] = result.model_dump()
        if not result.success:
            state["error"] = f"Browser agent: {result.error}"
    except Exception as exc:
        state["error"] = f"Browser agent error: {exc}"
        logger.error("[Workflow] Browser failed: %s", exc)
    finally:
        # Always close the browser regardless of outcome
        await browser_agent.close()

    return state


async def node_download(state: WorkflowState) -> WorkflowState:
    """
    Downloads the installer file.

    FIX: removed the __package_manager__ sentinel string.
    When the planner chose a package manager, use_package_manager=True
    and we set download.success=True with local_path=None.
    InstallAgent checks local_path is None and use_package_manager to decide
    whether to call _pkg_manager() directly.
    """
    state["current_step"] = "download"
    if state.get("error"):
        return state

    # Package-manager shortcut — no file to download
    if state.get("use_package_manager"):
        state["download"] = DownloadResult(
            success=True,
            local_path=None,   # explicit None, never a sentinel string
        ).model_dump()
        return state

    try:
        browser = BrowserResult(**state["browser"])

        if not browser.selected_link:
            state["error"] = "Browser found no download link to fetch"
            return state

        result: DownloadResult = await _download_agent.download_and_verify(
            browser.selected_link
        )
        state["download"] = result.model_dump()
        if not result.success:
            state["error"] = f"Download agent: {result.error}"
    except Exception as exc:
        state["error"] = f"Download agent error: {exc}"
        logger.error("[Workflow] Download failed: %s", exc)

    return state


async def node_install(state: WorkflowState) -> WorkflowState:
    """
    Runs the installer.

    FIX: no longer calls Path() on a sentinel string.
    Reads use_package_manager flag directly from state.
    Passes rag_context to InstallAgent so it can use documented silent-install flags.
    """
    state["current_step"] = "install"
    if state.get("error"):
        return state
    try:
        download    = DownloadResult(**state["download"])
        intent      = IntentOutput(**state["intent"])
        plan        = ExecutionPlan(**state["plan"])
        rag_context = state.get("rag_context")  # may be None

        package_id: Optional[str] = None
        if plan.steps:
            package_id = plan.steps[0].params.get("package_id")

        result: InstallResult = await _install_agent.install(
            download=download,
            software=intent.software_canonical,
            os_target=intent.operating_system,
            package_id=package_id,
            use_package_manager=state.get("use_package_manager", False),
            rag_context=rag_context,
        )
        state["install"] = result.model_dump()
        if not result.success:
            state["error"] = f"Install agent: {result.error}"
    except Exception as exc:
        state["error"] = f"Install agent error: {exc}"
        logger.error("[Workflow] Install failed: %s", exc)

    return state


async def node_notify(state: WorkflowState) -> WorkflowState:
    """
    Sends the final notification and captures install logs in Redis.

    FIX: original used hasattr(task, 'intent_output') which is always True
    on a Pydantic model (the field exists even when its value is None).
    Changed to value-level check: `if task.intent_output`.
    """
    state["current_step"] = "notify"
    try:
        install_r = InstallResult(**state["install"]) if state.get("install") else None
        task      = Task(**state["task"])

        task.status = (
            TaskStatus.COMPLETED
            if (install_r and install_r.success)
            else TaskStatus.FAILED
        )
        task.error = state.get("error")

        # Attach intent so NotificationAgent can name the software correctly
        if state.get("intent"):
            task.intent_output = IntentOutput(**state["intent"])

        if install_r:
            # FIX: was hasattr(task, 'intent_output') — always True
            if task.intent_output:
                await _monitor_agent.capture_logs(task.task_id, install_r.logs)

        await _notify_agent.notify(task)
    except Exception as exc:
        logger.error("[Workflow] Notify failed: %s", exc)

    return state


# ──────────────────────────────────────────────
# Routing conditions
# ──────────────────────────────────────────────

def _route_after_intent(state: WorkflowState) -> str:
    """Error short-circuits to notify. Otherwise always go to planner."""
    if state.get("error"):
        return "notify"
    return "planner"


def _route_after_planner(state: WorkflowState) -> str:
    """
    After planning, check human_in_loop flag.
    If enabled, go to the approval checkpoint before browser/download.
    """
    if state.get("error"):
        return "notify"
    if settings.features.human_in_loop:
        return "human_approval"
    return "browser"


def _route_after_approval(state: WorkflowState) -> str:
    """If approval was rejected (error set), skip to notify."""
    if state.get("error"):
        return "notify"
    return "browser"


def _route_after_download(state: WorkflowState) -> str:
    """
    FIX: original had dead code — both branches returned "planner".
    Now correctly routes download-only intent to notify (skip install).
    """
    if state.get("error"):
        return "notify"
    intent_data = state.get("intent", {})
    if intent_data.get("intent") == Intent.DOWNLOAD_ONLY.value:
        return "notify"
    return "install"


# ──────────────────────────────────────────────
# Build the LangGraph
# ──────────────────────────────────────────────

def build_workflow():
    g = StateGraph(WorkflowState)

    g.add_node("speech",         node_speech)
    g.add_node("intent",         node_intent)
    g.add_node("planner",        node_planner)
    g.add_node("human_approval", node_human_approval)
    g.add_node("browser",        node_browser)
    g.add_node("download",       node_download)
    g.add_node("install",        node_install)
    g.add_node("notify",         node_notify)

    g.set_entry_point("speech")

    g.add_edge("speech", "intent")

    g.add_conditional_edges("intent", _route_after_intent, {
        "planner": "planner",
        "notify":  "notify",
    })

    g.add_conditional_edges("planner", _route_after_planner, {
        "human_approval": "human_approval",
        "browser":        "browser",
        "notify":         "notify",
    })

    g.add_conditional_edges("human_approval", _route_after_approval, {
        "browser": "browser",
        "notify":  "notify",
    })

    g.add_edge("browser", "download")

    g.add_conditional_edges("download", _route_after_download, {
        "install": "install",
        "notify":  "notify",
    })

    g.add_edge("install", "notify")
    g.add_edge("notify",  END)

    return g.compile()


_workflow = build_workflow()


# ──────────────────────────────────────────────
# Public API
# ──────────────────────────────────────────────

async def run_voice_workflow(
    task: Task,
    audio_bytes: Optional[bytes] = None,
    text_query: Optional[str] = None,
    os_hint: Optional[str] = None,
) -> WorkflowState:
    """
    Entry point for both voice and text command paths.
    os_hint: OperatingSystem.value string forwarded from the text API.
    """
    initial: WorkflowState = {
        "task":                task.model_dump(),
        "audio_bytes":         audio_bytes,
        "text_query":          text_query,
        "os_hint":             os_hint,
        "speech":              None,
        "intent":              None,
        "plan":                None,
        "rag_context":         None,
        "browser":             None,
        "use_package_manager": False,
        "download":            None,
        "install":             None,
        "error":               None,
        "current_step":        "start",
        "retry_count":         0,
        "awaiting_approval":   False,
    }

    logger.info("[Workflow] Starting task=%s audio=%s text=%r",
                task.task_id, bool(audio_bytes), text_query)

    final_state: WorkflowState = await _workflow.ainvoke(initial)

    logger.info("[Workflow] Finished task=%s step=%s error=%s",
                task.task_id, final_state["current_step"], final_state.get("error"))
    return final_state