FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System deps: gcc for compiled packages, curl for healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ curl libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps first (layer cache)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application source
COPY app/ ./app/
COPY .env.example .env

# Expose FastAPI port (informational only — Railway routes via $PORT)
EXPOSE 8000

# Railway injects $PORT at runtime — shell form so it actually expands.
# Falls back to 8000 for local `docker run` without -e PORT=...
CMD uvicorn app.api.main:app --host 0.0.0.0 --port ${PORT:-8000} --log-level info